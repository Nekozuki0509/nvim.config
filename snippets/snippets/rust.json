snippet vec_util
    cargo_snippet_more::expanded!("vec_util");
    pub trait VecUtil<T> {
        fn get_or_default(&self, i: usize) -> T;
    }
    impl<T: Default + Copy> VecUtil<T> for Vec<T> {
        fn get_or_default(self: &Vec<T>, i: usize) -> T {
            self.get(i).copied().unwrap_or_default()
        }
    }

